---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';

const path = '/en/privacy';
---

<BaseLayout
  lang="en"
  title="Privacy Policy – Daniel Andres"
  description="Privacy policy for the personal website of Daniel Andres."
  {path}
>
  <Section title="Privacy Policy">
    <h3>Responsible Party</h3>
    <p>
      Daniel Andres<br />
      Musterstraße 123<br />
      12345 Musterstadt<br />
      Germany<br />
      Email: kontakt@daniel-andres.com
    </p>

    <h3>Collection and Storage of Personal Data</h3>
    <p>
      This website does not collect any personal data. No cookies are set and no analytics services such as Google Analytics are used. When accessing the site, technical access data (IP address, timestamp, requested page) is processed by the hosting provider and automatically deleted after a short period.
    </p>

    <h3>Your Rights</h3>
    <p>
      You have the right to request information about stored data, as well as correction, deletion, or restriction of processing at any time. Please contact the email address above for this purpose.
    </p>
  </Section>
</BaseLayout>
