---
export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function switchLang(path: string, toLang: 'de' | 'en'): string {
  const otherPath = currentPath.replace(/^\/(de|en)/, `/${toLang}`);
  return otherPath;
}
---

<div class="lang-switch">
  <a class:list={{ 'lang-link': true, 'lang-link--active': currentPath.startsWith('/de') }} href={switchLang(currentPath, 'de')}>DE</a>
  <span class="lang-separator">|</span>
  <a class:list={{ 'lang-link': true, 'lang-link--active': currentPath.startsWith('/en') }} href={switchLang(currentPath, 'en')}>EN</a>
</div>

<style>
  .lang-switch {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.875rem;
  }

  .lang-link {
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .lang-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .lang-link--active {
    color: var(--color-text);
    font-weight: 700;
  }

  .lang-separator {
    color: var(--color-border);
  }
</style>
