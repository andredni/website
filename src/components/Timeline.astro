---
import type { PortfolioEntry } from '../data/portfolio';

export interface Props {
  items: PortfolioEntry[];
}

const { items } = Astro.props;
---

<ol class="timeline">
  {items.map((entry) => (
    <li class="timeline__entry">
      <div class="timeline__marker" />
      <div class="timeline__content">
        <span class="timeline__period">{entry.period}</span>
        <h3 class="timeline__role">{entry.role}</h3>
        <p class="timeline__company">{entry.company}</p>
        <p class="timeline__description">{entry.description}</p>
        <div class="timeline__tags">
          {entry.technologies.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>
      </div>
    </li>
  ))}
</ol>

<style>
  .timeline {
    list-style: none;
    position: relative;
    padding-left: var(--spacing-xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.4375rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--color-border);
  }

  .timeline__entry {
    position: relative;
    padding-bottom: var(--spacing-2xl);
  }

  .timeline__entry:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: calc(-1 * var(--spacing-xl) + 0.25rem);
    top: 0.375rem;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
  }

  .timeline__period {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .timeline__role {
    font-size: 1.125rem;
    font-weight: 600;
    margin: var(--spacing-xs) 0 var(--spacing-xs);
  }

  .timeline__company {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
  }

  .timeline__description {
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  .timeline__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: var(--color-border);
    color: var(--color-text-muted);
  }
</style>
